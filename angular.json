						},
						"development": {
							"tsConfig": "libs/domain/boarding/tsconfig.lib.json"
						}
					},
					"defaultConfiguration": "production"
				},
				"test": {
					"builder": "@angular/build:unit-test",
					"options": {
						"tsConfig": "libs/domain/boarding/tsconfig.spec.json"
					}
				}
			}
		},
		"checkin": {
			"projectType": "library",
			"root": "libs/domain/checkin",
			"sourceRoot": "libs/domain/checkin/src",
			"prefix": "lib",
			"architect": {
				"build": {
					"builder": "@angular/build:ng-packagr",
					"configurations": {
						"production": {
							"tsConfig": "libs/domain/checkin/tsconfig.lib.prod.json"
						},
						"development": {
							"tsConfig": "libs/domain/checkin/tsconfig.lib.json"
						}
					},
					"defaultConfiguration": "production"
				},
				"test": {
					"builder": "@angular/build:unit-test",
					"options": {
						"tsConfig": "libs/domain/checkin/tsconfig.spec.json"
					}
				}
			}
		},
		"core": {
			"projectType": "library",
			"root": "libs/shared/core",
			"sourceRoot": "libs/shared/core/src",
			"prefix": "lib",
			"architect": {
				"build": {
					"builder": "@angular/build:ng-packagr",
					"configurations": {
						"production": {
							"tsConfig": "libs/shared/core/tsconfig.lib.prod.json"
						},
						"development": {
							"tsConfig": "libs/shared/core/tsconfig.lib.json"
						}
					},
					"defaultConfiguration": "production"
				},
				"test": {
					"builder": "@angular/build:unit-test",
					"options": {
						"tsConfig": "libs/shared/core/tsconfig.spec.json"
					}
				}
			}
		},
		"navigation": {
			"projectType": "library",
			"root": "libs/shared/navigation",
			"sourceRoot": "libs/shared/navigation/src",
			"prefix": "lib",
			"architect": {
				"build": {
					"builder": "@angular/build:ng-packagr",
					"configurations": {
						"production": {
							"tsConfig": "libs/shared/navigation/tsconfig.lib.prod.json"
						},
						"development": {
							"tsConfig": "libs/shared/navigation/tsconfig.lib.json"
						}
					},
					"defaultConfiguration": "production"
				},
				"test": {
					"builder": "@angular/build:unit-test",
					"options": {
						"tsConfig": "libs/shared/navigation/tsconfig.spec.json"
					}
				}
			}
		},
		"state": {
			"projectType": "library",
			"root": "libs/shared/state",
			"sourceRoot": "libs/shared/state/src",
			"prefix": "lib",
			"architect": {
				"build": {
					"builder": "@angular/build:ng-packagr",
					"configurations": {
						"production": {
							"tsConfig": "libs/shared/state/tsconfig.lib.prod.json"
						},
						"development": {
							"tsConfig": "libs/shared/state/tsconfig.lib.json"
						}
					},
					"defaultConfiguration": "production"
				},
				"test": {
					"builder": "@angular/build:unit-test",
					"options": {
						"tsConfig": "libs/shared/state/tsconfig.spec.json"
					}
				}
			}
		},
